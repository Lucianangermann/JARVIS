# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# === Anthropic API ===
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# === JARVIS auth ===
# Bearer token every client must send. Generate a strong one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JARVIS_AUTH_TOKEN=replace-with-a-long-random-token

# === Server binding ===
# 127.0.0.1 = localhost only (safest default).
# 0.0.0.0   = listen on all interfaces — only do this on a trusted LAN.
HOST=127.0.0.1
PORT=8000

# === CORS ===
# Comma-separated list of allowed origins for the web client.
# For iPhone access on LAN, add e.g. http://192.168.1.50:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === Model ===
# claude-haiku-4-5-20251001 is the dated Haiku 4.5 ID per project spec.
MODEL=claude-haiku-4-5-20251001

# === Voice / wake word ===
WAKE_WORD=jarvis
WHISPER_MODEL=base            # tiny | base | small | medium | large
# Set to 1 to run the local mic + TTS loop on the MacBook server itself.
# Requires the voice stack (requirements-voice.txt) to be installed.
JARVIS_LOCAL_VOICE=0

# TTS voice. Leave empty to autoselect a male German voice
# (Markus → Yannick → Eddy/Grandpa → Anna fallback).
# Examples on macOS: Markus, Yannick, Anna, Petra, Helena.
# To list available system voices:
#   say -v "?"
# Premium voices like Markus need to be downloaded once via
# Systemeinstellungen → Bedienungshilfen → Gesprochene Inhalte → Systemstimme.
TTS_VOICE=Markus
TTS_LANGUAGE=de
TTS_RATE=180

# === System prompt ===
SYSTEM_PROMPT=Du bist JARVIS, ein knapper und fähiger Sprachassistent. Antworte immer in derselben Sprache, in der der Nutzer gesprochen hat; bei Unklarheit antworte auf Deutsch. Deine Antworten werden vorgelesen, also schreibe reinen Fließtext: kein Markdown, keine Sternchen, keine Aufzählungspunkte, keine Überschriften, keine Codeblöcke. Halte die Antwort unter drei Sätzen, außer der Nutzer fragt explizit nach mehr Detail. Lehne alles ab, was außerhalb der erlaubten Befehle liegt.
