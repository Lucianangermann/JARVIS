# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# === Anthropic API ===
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# === JARVIS auth ===
# Bearer token every client must send. Generate a strong one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JARVIS_AUTH_TOKEN=replace-with-a-long-random-token

# === Server binding ===
# 127.0.0.1 = localhost only (safest default).
# 0.0.0.0   = listen on all interfaces — only do this on a trusted LAN.
HOST=127.0.0.1
PORT=8000

# === HTTPS (required for the iPhone PWA at /app) ===
# iOS Safari blocks both microphone access and Add-to-Home-Screen
# unless the page is served over HTTPS. If you've got the project
# inside Tailscale, the easiest setup is to use Tailscale's per-host
# cert files (machine-name.tailnet.ts.net.crt + .key) that already
# live in the repo root. Leave empty to run HTTP (Electron-only).
#
# JARVIS_SSL_CERT=./macbook-pro-von-lucian-1.tail1a2633.ts.net.crt
# JARVIS_SSL_KEY =./macbook-pro-von-lucian-1.tail1a2633.ts.net.key
JARVIS_SSL_CERT=
JARVIS_SSL_KEY=

# === CORS ===
# Comma-separated list of allowed origins for the web client.
# For iPhone access on LAN, add e.g. http://192.168.1.50:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === Model ===
# claude-haiku-4-5-20251001 is the dated Haiku 4.5 ID per project spec.
MODEL=claude-haiku-4-5-20251001

# === Voice / wake word ===
WAKE_WORD=jarvis

# STT backend:
#   auto    — macOS Speech.framework (sub-second, native, on-device)
#             if available + authorised, otherwise Whisper. RECOMMENDED.
#   macos   — force Speech.framework. Refuses to start without permission.
#   whisper — force faster-whisper / openai-whisper (cross-platform).
# On first use, macOS shows a permission dialog. To reset for testing:
#   tccutil reset SpeechRecognition
STT_BACKEND=auto

WHISPER_MODEL=small           # tiny | base | small | medium | large | large-v3-turbo
                              # 'small' is the sweet spot for German voice
                              # commands. 'base' often gets short German
                              # words wrong ("stopp" -> "up"). 'medium'
                              # is more accurate but ~2× slower than
                              # 'small'. 'large-v3-turbo' is designed
                              # for speech-only and runs at ~small's
                              # latency with near-large accuracy — best
                              # quality/latency trade-off if RAM
                              # (~2 GB during decode) is fine.

# Beam size for faster-whisper. 1 = greedy decoding, ~3-5× faster than
# 5 with minimal accuracy loss on short commands. Bump to 5 for the
# original quality target, 8 for long-form transcription.
WHISPER_BEAM_SIZE=1

# Set to 1 to run the local mic + TTS loop on the MacBook server itself.
# Requires the voice stack (requirements-voice.txt) to be installed.
JARVIS_LOCAL_VOICE=0

# TTS voice. Leave empty to autoselect a male German voice
# (Markus → Yannick → Eddy/Grandpa → Anna fallback).
# Examples on macOS: Markus, Yannick, Anna, Petra, Helena.
# To list available system voices:
#   say -v "?"
# Premium voices like Markus need to be downloaded once via
# Systemeinstellungen → Bedienungshilfen → Gesprochene Inhalte → Systemstimme.
TTS_VOICE=Markus
TTS_LANGUAGE=de
TTS_RATE=180

# Follow-up mode: after the wake word fires JARVIS stays "active" for
# this many seconds. Every utterance in that window is a command — no
# wake word needed. Refreshes after each reply. Ends when you say
# "okay das war's" / "tschüss" / "stopp" / "ende".
# Set to 0 to disable (every command needs the wake word).
FOLLOWUP_TIMEOUT_S=60

# === Spotify Web API (optional — needed only for "spiel Song X" / "spiel Playlist Y") ===
# Create a free developer app at https://developer.spotify.com/dashboard
# (no premium account required). Copy Client ID + Client Secret here.
# Without these, only play/pause/next/previous work — JARVIS can't search.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=DE

# === System prompt ===
SYSTEM_PROMPT=Du bist JARVIS, ein knapper und fähiger Sprachassistent. Antworte immer in derselben Sprache, in der der Nutzer gesprochen hat; bei Unklarheit antworte auf Deutsch. Deine Antworten werden vorgelesen, also schreibe reinen Fließtext: kein Markdown, keine Sternchen, keine Aufzählungspunkte, keine Überschriften, keine Codeblöcke. Halte die Antwort unter drei Sätzen, außer der Nutzer fragt explizit nach mehr Detail. Lehne alles ab, was außerhalb der erlaubten Befehle liegt.
